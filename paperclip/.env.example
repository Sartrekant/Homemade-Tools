# ─────────────────────────────────────────────
# Paperclip environment config
# Copy to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── Required ─────────────────────────────────

# Secret used to sign auth tokens. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── AI provider keys ─────────────────────────
# At least one is needed to run agents.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Server ───────────────────────────────────

# Port the server listens on (default: 3100)
PORT=3100

# Public-facing URL — required in production so agents can call back.
# Local: http://localhost:3100
# Prod:  https://paperclip.yourdomain.com
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# ── Deployment mode ──────────────────────────

# authenticated = login required (recommended for client hosting)
# unauthenticated = no login (local dev only)
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# private = only accessible to logged-in users
# public  = board visible without login (demo / showcase)
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# ── Data storage ─────────────────────────────

# Host path for Paperclip's data volume (local docker-compose.yml only)
PAPERCLIP_DATA_DIR=./data

# ── Production only (docker-compose.prod.yml) ─

# Postgres password — used to build the DATABASE_URL inside the container
POSTGRES_PASSWORD=

# If you bring your own external postgres instead:
# DATABASE_URL=postgres://user:password@host:5432/paperclip
